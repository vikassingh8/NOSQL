# One-shot seeder: creates Cassandra schema + seeds Mongo/Cassandra/Neo4j.
# Built from the repo root; run once against the running stack.
FROM node:22-alpine
WORKDIR /app
COPY package.json ./
COPY services/shared/package.json services/shared/package.json
RUN npm install --omit=dev --workspaces --include-workspace-root || npm install --omit=dev
COPY services/shared services/shared
COPY scripts scripts
CMD ["node", "scripts/seed-all.js"]
