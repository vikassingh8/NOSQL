# ─── Copy to .env and adjust as needed ──────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=telemetry

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
HEALTH_TTL_SECONDS=120

# ─── Cassandra ──────────────────────────────────────────────────────────────
CASSANDRA_CONTACT_POINTS=localhost
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_KEYSPACE=telemetry

# ─── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ─── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=orbital-telemetry
KAFKA_TELEMETRY_TOPIC=telemetry.raw
KAFKA_ALERTS_TOPIC=telemetry.alerts
KAFKA_CONSUMER_GROUP=ingestion-group

# ─── API / Auth ─────────────────────────────────────────────────────────────
API_PORT=4000
ALERT_PORT=4100
JWT_SECRET=change-me-in-prod-super-secret-key
JWT_EXPIRES_IN=1h
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ─── Simulator ──────────────────────────────────────────────────────────────
SIM_SATELLITES=SAT-01,SAT-02,SAT-03
SIM_INTERVAL_MS=1000
SIM_ANOMALY_RATE=0.05
