{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Orbital Telemetry — Overview",
  "tags": ["telemetry", "nosql"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Ingestion rate (packets/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(telemetry_ingested_total[1m]))", "legendFormat": "ingested/s" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Alerts emitted (per severity)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(alerts_emitted_total[5m])) by (severity)", "legendFormat": "{{severity}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Processing latency p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(telemetry_processing_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    },
    {
      "type": "stat",
      "title": "Ingest errors (total)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(telemetry_ingest_errors_total)" }]
    },
    {
      "type": "timeseries",
      "title": "API latency p95 (s)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }
      ]
    }
  ]
}
